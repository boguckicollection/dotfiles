syntax on
set number
set relativenumber
set cursorline

set tabstop=4
set shiftwidth=4
set expandtab
set autoindent
set smartindent

set incsearch
set hlsearch
set ignorecase
set smartcase

set scrolloff=5
set wildmenu
set showmatch
set mouse=a
set clipboard=unnamedplus
set backspace=indent,eol,start

set background=dark
colorscheme habamax
